{
  "expo": {
    "name": "PaisoPulse",
    "slug": "ledger-app",
    "version": "1.0.1",
    "scheme": "ledger",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/PaisoPulse-logo.png",
    "splash": {
      "image": "./assets/PaisoPulse-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#443821"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.niyaz.ledger"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/PaisoPulse-logo.png",
        "backgroundColor": "#443821"
      },
      "package": "com.niyaz.ledger",
      "versionCode": 2
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08145e43-e0d4-4a1d-9be4-7cc0ed2c17a3"
      }
    }
  }
}
